# Environment
ENVIRONMENT=development
DEBUG=true

# API Configuration
API_TITLE=Syda API
API_VERSION=1.0.0

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
